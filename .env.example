# HA Sandbox Analyzer — Environment Variables
# Copy to .env and fill in your values

# MQTT (for Home Assistant auto-discovery)
MQTT_HOST=localhost
MQTT_PORT=8883
MQTT_USER=
MQTT_PASS=

# Home Assistant (for fetching installed HACS list)
HA_URL=http://homeassistant:8123
HA_TOKEN=

# Ollama (local AI model)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=gemma3:12b
